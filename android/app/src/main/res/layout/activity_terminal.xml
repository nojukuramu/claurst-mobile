<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1e2e">

    <!--
        Full-screen WebView running xterm.js.
        The TerminalActivity wires up the JavascriptInterface and loads
        file:///android_asset/terminal.html into this view.
    -->
    <WebView
        android:id="@+id/web_view_terminal"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/terminal_status_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#CC1E1E2E">

        <ProgressBar
            android:id="@+id/progress_terminal"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tv_terminal_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="@string/terminal_status_loading"
            android:textColor="#CDD6F4"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
